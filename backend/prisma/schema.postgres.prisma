// Para produção (Railway/Supabase): copie para schema.prisma
// cp schema.postgres.prisma schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  users      User[]
  clients    Client[]
  activities Activity[]
}

model User {
  id                    String   @id @default(cuid())
  email                 String
  name                  String
  passwordHash          String
  role                  String
  tenantId              String
  cargo                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  cargaHorariaSemanal   Float?   @default(40)
  permitirMaisHoras     Boolean  @default(false)
  permitirFimDeSemana   Boolean  @default(false)
  permitirOutroPeriodo  Boolean  @default(false)
  diasPermitidos        String?

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdProjects       Project[]     @relation("ProjectCreator")
  timeEntries           TimeEntry[]
  assignedTickets       Ticket[]      @relation("AssignedConsultant")
  createdTickets        Ticket[]      @relation("TicketCreator")
  hourBankRecords       HourBankRecord[]
  clientAccess          ClientUser[]  @relation("ClientUser")
  @@unique([email, tenantId])
  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  Project[]
  users     ClientUser[]
}

model ClientUser {
  id       String  @id @default(cuid())
  userId   String
  clientId String
  user     User    @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([userId, clientId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  clientId    String
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("ProjectCreator", fields: [createdById], references: [id])
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  arquivado   Boolean  @default(false)
  arquivadoEm DateTime?
  tickets     Ticket[]
  timeEntries TimeEntry[]
}

model Ticket {
  id           String   @id @default(cuid())
  code         String
  title        String
  description  String?
  type         String
  criticidade  String?
  status       String   @default("ABERTO")
  projectId    String
  createdById  String?
  assignedToId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User?    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo   User?    @relation("AssignedConsultant", fields: [assignedToId], references: [id])
  timeEntries  TimeEntry[]
}

model Activity {
  id          String      @id @default(cuid())
  name        String
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
}

model TimeEntry {
  id              String    @id @default(cuid())
  date            DateTime
  horaInicio      String
  horaFim         String
  intervaloInicio String?
  intervaloFim    String?
  totalHoras      Float
  description     String?
  userId          String
  projectId       String
  ticketId        String?
  activityId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticket          Ticket?   @relation(fields: [ticketId], references: [id])
  activity        Activity? @relation(fields: [activityId], references: [id])
}

model HourBankRecord {
  id                  String   @id @default(cuid())
  month               Int
  year                Int
  horasPrevistas      Float
  horasTrabalhadas    Float
  horasComplementares Float?
  horasPagas          Float?
  observacao          String?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, month, year])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
